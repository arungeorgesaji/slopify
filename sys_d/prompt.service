[Unit]
Description=Prompt builder for slopify
After=network.target

[Service]
WorkingDirectory=%h/slopify/prompt
EnvironmentFile=%h/slopify/prompt/.env
ExecStart=%h/slopify/prompt/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 30001 --reload
Restart=on-failure
Environment="PATH=%h/slopify/prompt/venv/bin:/usr/bin"

[Install]
WantedBy=default.target
